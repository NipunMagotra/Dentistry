# ===================================================================
# Clinic OS - Firebase & App Environment Variables
# ===================================================================
# Copy this file to .env.local and fill in your credentials.

# Required for Upstash Workflow (SMS/WhatsApp notifications & signature verification):
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Root domain for multi-tenant subdomain routing
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Firebase Admin SDK Credentials (from Firebase Console -> Project Settings -> Service Accounts)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."

# Secret Key for AES-256-GCM field encryption of sensitive prescription notes (32+ characters)
ENCRYPTION_SECRET=your_32_character_encryption_secret_here

# Secret Key for Tenant Session Cookie JWTs
SESSION_SECRET=your_tenant_session_secret
