# ===================================================================
# Clinic OS - Environment Variables
# ===================================================================
# Copy this file to .env.local and fill in the values.
#
# Required for Upstash Workflow (SMS/WhatsApp notifications):
QSTASH_TOKEN=

# Optional: Root domain for multi-tenant subdomain routing.
# Default: localhost:3000 (used in middleware.ts)
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
